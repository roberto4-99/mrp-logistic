.logo{
  width:42px;
  height:42px;
  border-radius:50%;
  overflow:hidden;
  background: rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.14);
  display:flex;
  align-items:center;
  justify-content:center;
  flex:0 0 auto;
}

.logo img{
  width:100%;
  height:100%;
  object-fit:cover;
  display:block;
}